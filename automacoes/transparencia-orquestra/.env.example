# Copie para .env e preencha. NUNCA commite o .env preenchido.

# Panorama Fiscal — URL de entrada/login
PANORAMA_URL=https://panoramafiscal.com.br/svd

# Credenciais
PANORAMA_USER=
PANORAMA_PASS=

# CSV gerado pela Fase 1 (transparencia-bayeux)
# Default: ../transparencia-bayeux/out/report.csv
CSV_PATH=

# Defaults pro formulário (opcionais)
DEFAULT_GESTOR=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_FISCAL=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_TIPO_CONTRATO=CONTRATO
