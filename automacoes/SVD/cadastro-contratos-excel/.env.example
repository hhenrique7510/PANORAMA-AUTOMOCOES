# Copie para .env e preencha. NUNCA commite o .env preenchido.

# URL de entrada/login do Panorama Fiscal.
PANORAMA_URL=https://panoramafiscal.com.br/svd

# Credenciais de acesso
PANORAMA_USER=
PANORAMA_PASS=

# Caminho absoluto do arquivo .xlsx com a lista de contratos.
XLSX_PATH=/Users/henriqueroma/Downloads/GESTÃO DE CONTRATOS - 24-04 - PARA ANA E ALEXANDRE.xlsx

# Nome da aba (default: Planilha1)
XLSX_SHEET=Planilha1

# Linha do header no Excel (1-indexado, ex: 7 = a linha com "ARP/CONTRATO Nº STATUS ...").
XLSX_HEADER_ROW=7

# Defaults pro formulário (opcionais)
DEFAULT_GESTOR=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_FISCAL=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_TIPO_CONTRATO=CONTRATO
