# Copie para .env e preencha. NUNCA commite o .env preenchido.

# URL normal de entrada/login. O bot loga aqui e navega sozinho pra
# /svd/contratos e /svd/contrato/salvar.
PANORAMA_URL=https://panoramafiscal.com.br/svd

# Credenciais de acesso
PANORAMA_USER=
PANORAMA_PASS=

# Pasta onde estão os PDFs a processar (caminho absoluto)
PDF_DIR=/Users/henriqueroma/Downloads/CONTRATOS PROCESSOS 2026

# Defaults pro formulário (opcionais) — só usados se for CRIAR contrato novo
DEFAULT_GESTOR=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_FISCAL=PREFEITURA MUNICIPAL DE BAYEUX
DEFAULT_TIPO_CONTRATO=CONTRATO

# Por padrão o bot só ANEXA o PDF em contratos que já existem. Se quiser que ele
# CRIE o contrato quando o número não estiver na listagem, descomente:
# PANORAMA_CRIAR_SE_NAO_EXISTIR=1

# Sobrescrever os caminhos internos (opcional — derivados do domínio por padrão):
# PANORAMA_CONTRATOS_URL=https://panoramafiscal.com.br/svd/contratos
# PANORAMA_NOVO_CONTRATO_URL=https://panoramafiscal.com.br/svd/contrato/salvar
# PANORAMA_ALTERAR_URL_TMPL=https://panoramafiscal.com.br/svd/contrato/alterar/{id}
